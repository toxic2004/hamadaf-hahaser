{
  "name": "hamadaf-hahaser",
  "version": "2.0.0",
  "private": true,
  "description": "המדף החסר",
  "scripts": {
    "format:check": "prettier --check \"*.{html,js,css,json,md}\" \".github/workflows/*.yml\" \"supabase/functions/**/*.ts\"",
    "lint": "eslint . && html-validate \"*.html\"",

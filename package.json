    "build": "node scripts/build.mjs"
  },
  "devDependencies": {
    "eslint": "9.8.0",
    "exceljs": "4.4.0",
    "html-validate": "8.24.2",
    "jsdom": "24.1.1",
    "prettier": "3.3.3",
    "typescript": "5.5.4"
  }
}
